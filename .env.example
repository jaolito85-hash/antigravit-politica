# Supabase (Projeto separado para política)
SUPABASE_URL=your_supabase_url
SUPABASE_KEY=your_supabase_anon_key
SUPABASE_SERVICE_KEY=your_supabase_service_role_key

# Evolution API (WhatsApp)
EVOLUTION_API_URL=your_evolution_url
EVOLUTION_API_KEY=your_evolution_key
EVOLUTION_INSTANCE_NAME=your_instance

# OpenAI
OPENAI_API_KEY=your_openai_key

# Apify (Instagram scraper)
# Cadastro gratuito: https://apify.com → Settings → Integrations → API token
# Free tier: US$5/mês de crédito (~5.000 posts)
APIFY_TOKEN=your_apify_token

# Server
PORT=5004
